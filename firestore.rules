rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Check if the user is a member of the community (active status)
    function isCommunityMember(communityId) {
      let memberId = communityId + "_" + request.auth.uid;
      let memberPath = /databases/$(database)/documents/community_members/$(memberId);
      return exists(memberPath) &&
             get(memberPath).data.status == 'active';
    }

    // Check if the user has specific roles in the community
    function hasCommunityRole(communityId, roles) {
      let memberId = communityId + "_" + request.auth.uid;
      let memberPath = /databases/$(database)/documents/community_members/$(memberId);
      let memberData = get(memberPath).data;
      return exists(memberPath) &&
             memberData.status == 'active' &&
             memberData.role in roles;
    }

    function isCommunityAdmin(communityId) {
      return hasCommunityRole(communityId, ['owner', 'admin']);
    }

    function isCommunityOwner(communityId) {
      return hasCommunityRole(communityId, ['owner']);
    }

    // Check if the current user has superadmin or admin role at the app level.
    // Used to gate admin panel operations (ban user, assign role, feature community, etc.)
    function isAppAdmin() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() &&
             exists(userPath) &&
             get(userPath).data.role in ['superadmin', 'admin'];
    }

    // --- User Collection ---

    // Privileged fields (role, status, plan) can only be written via Admin SDK
    // (Cloud Functions). Client writes to these fields are explicitly denied.
    match /users/{userId} {
      allow read: if isAuthenticated();

      // Users can create their own profile doc but cannot set privileged fields
      allow create: if isOwner(userId) &&
                    !request.resource.data.keys().hasAny(['role', 'status', 'plan']);

      // Users can update their own profile but cannot modify privileged fields.
      // App-level admins (superadmin/admin role) can update any field, including
      // privileged ones (role, status, plan) — required for banUser/assignRole operations.
      allow update: if (isOwner(userId) &&
                        !request.resource.data.diff(resource.data)
                          .affectedKeys().hasAny(['role', 'status', 'plan'])) ||
                    isAppAdmin();

      // Profile deletion is handled server-side only
      allow delete: if false;

      // Notifications: Read-only for the user, write restricted (System/Admin SDK only)
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }

    // --- Community Members Collection (Root Level) ---
    // ID Format: communityId_userId
    match /community_members/{memberId} {
        // Read: Members can see other members of the SAME community.
        // But since we don't strictly know communityId from memberId wildcard easily in a single check without parsing,
        // we rely on the resource data `communityId`.
        // A user can read a member doc IF:
        // 1. They are reading their OWN doc
        // 2. They are a member of the community referred to by this doc
        
        allow read: if isAuthenticated() && 
                    (
                      resource.data.uid == request.auth.uid ||
                      isCommunityMember(resource.data.communityId)
                    );

        // Create/Join:
        // User creates their own membership doc (Requesting to join or joining public)
        allow create: if isAuthenticated() &&
                      request.resource.data.uid == request.auth.uid &&
                      // Ensure ID matches format constraint if possible, or just rely on data integrity
                      memberId == request.resource.data.communityId + "_" + request.auth.uid;

        // Update:
        // 1. Admins of the community can update roles/status
        // 2. User can update their own status (leave) but NOT role
        // BUG FIX #3: totalMalas and totalMantras must be included in the allowed self-update
        // keys so that the communityJapaService transaction can update member contribution
        // totals. Without this, every japa entry transaction is blocked → permission-denied.
        allow update: if isAuthenticated() &&
                      (
                        isCommunityAdmin(resource.data.communityId) ||
                        (
                           resource.data.uid == request.auth.uid &&
                           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'lastReadAnnouncementsAt', 'lastReadChatAt', 'notificationPrefs', 'totalMalas', 'totalMantras'])
                        )
                      );
                      
        allow delete: if isAuthenticated() && isCommunityOwner(resource.data.communityId);
    }

    // --- Communities Collection ---

    match /communities/{communityId} {
      // Read: Public communities readable by all, Private by members only.
      // App admins can read all communities (required for admin stats count + panel).
      allow read: if resource.data.isPrivate == false || isCommunityMember(communityId) || isAppAdmin();
      
      // Create: Any authenticated user can create a community
      allow create: if isAuthenticated();
      
      // Update: 
      // 1. Admin/Owner can update settings.
      // 2. Any Auth user can update counters (membersCount, totalMalas, totalMantras) - needed for joining/chanting.
      allow update: if isCommunityAdmin(communityId) || 
                    (
                      isAuthenticated() && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['membersCount', 'totalMalas', 'totalMantras'])
                    );
      
      // Delete: Only Owner
      allow delete: if isCommunityOwner(communityId);

      // --- Posts Subcollection ---
      match /posts/{postId} {
        // Read: Active members
        allow read: if isCommunityMember(communityId);
        
        // Create: Active members. 
        allow create: if isCommunityMember(communityId) &&
                      (request.resource.data.type == 'announcement' ? isCommunityAdmin(communityId) : true) &&
                      request.resource.data.authorId == request.auth.uid;

        // Update: 
        allow update: if isCommunityMember(communityId) && 
                      (
                        (resource.data.authorId == request.auth.uid) || 
                        isCommunityAdmin(communityId)
                      );
      }

      // --- Chat Subcollection ---
      // --- Chat Subcollection ---
      match /chat_messages/{messageId} {
        allow read: if isCommunityMember(communityId);
        
        allow create: if isCommunityMember(communityId) && 
                      request.resource.data.senderId == request.auth.uid;
                      
        // Update: Soft-delete only
        allow update: if isCommunityMember(communityId) &&
                      (
                        (resource.data.senderId == request.auth.uid) || 
                        isCommunityAdmin(communityId)
                      );
      }

      // --- Japa Entries Subcollection ---
      match /japa_entries/{entryId} {
        allow read: if isCommunityMember(communityId);
        
        // Create: Immutable
        allow create: if isCommunityMember(communityId) && 
                      request.resource.data.uid == request.auth.uid;
                      
        // Immutable
        allow update, delete: if false;
      }
    }

    // --- Pledges Collection (Legacy/Global) ---
    match /pledges/{pledgeId} {
        allow read: if true; // Public pledges
        allow create: if isAuthenticated();
        // BUG FIX #4: contribute() increments currentMalas for any participant, not just
        // the creator. Allow any authenticated user to update only the currentMalas counter.
        // All other field edits (title, description, targetMalas, etc.) remain creator-only.
        allow update: if isAuthenticated() &&
                      (
                        resource.data.creatorId == request.auth.uid ||
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentMalas'])
                      );
    }

    // --- User Pledges Subcollection (Legacy) ---
    // Note: The code might be fetching `users/{uid}/pledges` or similar.
    // Based on previous logs, it seems to be root `pledges` and maybe `user_pledges`?
    // Let's check CommunityContext.tsx to be sure, but adding this here is safe.

     match /users/{userId}/pledges/{pledgeId} {
        allow read, write: if isOwner(userId);
    }

    // --- Pledge Participants (Legacy/Global) ---
    match /pledge_participants/{participantId} {
        // Read: if user is owner of the participant doc OR it's public data (for leaderboards)?
        // Context code queries: where('userId', '==', user.uid) -> So users read their own participation.
        allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

        // Also allow reading by anyone if it's for public stats?
        // For now, strict: only own.

        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;

        // Delete: user can remove their own participation (leave pledge) OR admins can clean up
        allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAppAdmin());
    }

    // --- Community Join Requests ---
    // ID Format: communityId_userId
    match /community_join_requests/{reqId} {
        // Read: Community admins can view pending requests for their community
        allow read: if isAuthenticated() && isCommunityAdmin(resource.data.communityId);

        // Create: Authenticated user can submit a join request for themselves
        allow create: if isAuthenticated() &&
                      request.resource.data.user.uid == request.auth.uid &&
                      request.resource.data.status == 'pending';

        // Update: Community admin can approve/reject (change status)
        allow update: if isAuthenticated() && isCommunityAdmin(resource.data.communityId);

        // Delete: Community admin can clean up approved/rejected requests
        allow delete: if isAuthenticated() && isCommunityAdmin(resource.data.communityId);
    }

    // --- Admin Audit Logs ---
    // Write-only for app admins (superadmin/admin). Read also restricted to admins.
    // No client should ever delete audit logs.
    match /admin_logs/{logId} {
        allow read: if isAppAdmin();
        allow create: if isAppAdmin();
        allow update, delete: if false;
    }

    // --- Global Stats (read by admin dashboard) ---
    match /global_stats/{docId} {
        allow read: if isAuthenticated();
        allow write: if false; // Written only by Cloud Functions via Admin SDK
    }
  }
}
