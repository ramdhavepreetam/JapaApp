rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Check if the user is a member of the community (active status)
    function isCommunityMember(communityId) {
      let memberPath = /databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid);
      return exists(memberPath) && 
             get(memberPath).data.status == 'active';
    }

    // Check if the user has specific roles in the community
    function hasCommunityRole(communityId, roles) {
      let memberPath = /databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid);
      let memberData = get(memberPath).data;
      return exists(memberPath) && 
             memberData.status == 'active' && 
             memberData.role in roles;
    }
    
    function isCommunityAdmin(communityId) {
      return hasCommunityRole(communityId, ['owner', 'admin']);
    }

    function isCommunityOwner(communityId) {
      return hasCommunityRole(communityId, ['owner']);
    }

    // --- User Collection ---
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);

      // Notifications: Read-only for the user, write restricted (System/Admin SDK only)
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }

    // --- Communities Collection ---

    match /communities/{communityId} {
      // Read: Public communities readable by all, Private by members only
      allow read: if resource.data.isPrivate == false || isCommunityMember(communityId);
      
      // Create: Any authenticated user can create a community
      allow create: if isAuthenticated();
      
      // Update: Only Owner/Admin can update settings. 
      // Soft-delete logic could be added here if 'deletedAt' is used for communities too.
      allow update: if isCommunityAdmin(communityId);
      
      // Delete: Only Owner? Or not allowed? Assuming strictly soft-delete or owner-only.
      allow delete: if isCommunityOwner(communityId);

      // --- Members Subcollection ---
      // /communities/{cid}/members/{uid}
      match /members/{memberId} {
        // Read: Members can see other members
        allow read: if isCommunityMember(communityId);
        
        // Create/Join: 
        // 1. User can request to join (create their own doc with status 'pending')
        // 2. Direct join if public? (Depending on logic, but rules allow creation if it's their own id)
        allow create: if isAuthenticated() && 
                      request.auth.uid == memberId;
                      
        // Update: 
        // 1. Admins can update roles/status (approve, ban, promote)
        // 2. User can update their own doc (e.g. leave community) - *Be careful with role escalation*
        allow update: if isCommunityAdmin(communityId) || 
                      (request.auth.uid == memberId && 
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status'])); // User can't change their own role/status autonomously unless leaving? 
                       // Simplified for prompt: "Only owner/admin can update community settings and membership approval/ban/promote"
                       // So we strictly limit status/role changes to admins.
        
        allow delete: if isCommunityOwner(communityId); // Or admins removing members
      }

      // --- Posts Subcollection ---
      match /posts/{postId} {
        // Read: Active members
        allow read: if isCommunityMember(communityId);
        
        // Create: Active members. 
        // Constraint: "Announcements only owner/admin; posts by active members."
        allow create: if isCommunityMember(communityId) &&
                      (request.resource.data.type == 'announcement' ? isCommunityAdmin(communityId) : true) &&
                      request.resource.data.authorId == request.auth.uid;

        // Update: 
        // 1. Soft-delete: User can soft-delete own. Admin can soft-delete any.
        // 2. Edit: User can edit own.
        allow update: if isCommunityMember(communityId) && 
                      (
                        (resource.data.authorId == request.auth.uid) || 
                        isCommunityAdmin(communityId)
                      );
      }

      // --- Chat Subcollection ---
      match /chat/{messageId} {
        allow read: if isCommunityMember(communityId);
        
        allow create: if isCommunityMember(communityId) && 
                      request.resource.data.authorId == request.auth.uid;
                      
        // Update: Soft-delete only (or edit if allowed). 
        // "Users can soft-delete own messages; admin can soft-delete any."
        allow update: if isCommunityMember(communityId) &&
                      (
                        (resource.data.authorId == request.auth.uid) || 
                        isCommunityAdmin(communityId)
                      );
      }

      // --- Japa Entries Subcollection ---
      match /japa_entries/{entryId} {
        allow read: if isCommunityMember(communityId);
        
        // Create: Immutable, uid == auth.uid
        allow create: if isCommunityMember(communityId) && 
                      request.resource.data.uid == request.auth.uid;
                      
        // Immutable: No update or delete allowed
        allow update, delete: if false;
      }
    }
  }
}
